APP_ENV=production
APP_DEBUG=0
SECRET_KEY=replace-with-long-production-secret
DATABASE_URL=postgresql+psycopg://db_user:db_password@db-host.example.com:5432/snchatbot?sslmode=require
RUN_MIGRATIONS_ON_STARTUP=1
CORS_ORIGINS=https://your-production-frontend.example
CORS_ALLOW_CREDENTIALS=1
MAX_REQUEST_BODY_BYTES=1048576
HTTPS_REDIRECT=1
TRUSTED_HOSTS=your-production-api.example,sureshhari-snchatbot-backend.hf.space
PROXY_HEADERS=1
FORWARDED_ALLOW_IPS=*
HOST=0.0.0.0
PORT=7860
WEB_CONCURRENCY=2
UVICORN_LOG_LEVEL=info
RUN_MIGRATIONS_BEFORE_START=0

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=15
EMAIL_VERIFICATION_EXPIRE_MINUTES=30
PASSWORD_MIN_LENGTH=8
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCKOUT_MINUTES=15
RESEND_VERIFICATION_COOLDOWN_SECONDS=60

# Use your Android/web deep links here when ready. For Hugging Face MVP fallback pages:
# FRONTEND_VERIFY_URL=https://sureshhari-snchatbot-backend.hf.space/verify-email
# FRONTEND_RESET_URL=https://sureshhari-snchatbot-backend.hf.space/reset-password
FRONTEND_VERIFY_URL=https://your-production-frontend.example/verify-email
FRONTEND_RESET_URL=https://your-production-frontend.example/reset-password

# Hugging Face Spaces should use HTTPS email APIs because outbound SMTP ports are blocked.
EMAIL_PROVIDER=resend
RESEND_API_KEY=replace-with-resend-api-key
RESEND_API_URL=https://api.resend.com/emails

# SMTP fields are kept for non-Hugging Face deployments. They are ignored when EMAIL_PROVIDER=resend.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=production-sender@example.com
EMAIL_PASSWORD=replace-with-app-password
EMAIL_FROM=production-sender@example.com
EMAIL_FROM_NAME=Jewellery Chat
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT_SECONDS=10

OMS_ENABLED=1
OMS_BASE_URL=https://your-production-oms.example/api
OMS_API_KEY=replace-with-production-oms-token
OMS_TIMEOUT_SECONDS=10

LLM_ENABLED=1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-production-llm-key
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=350

MONITORING_WEBHOOK_URL=https://your-production-alert-webhook.example
MONITORING_WEBHOOK_TIMEOUT_SECONDS=5
SENTRY_DSN=
SENTRY_RELEASE=snchatbot-backend-production
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=0
ALERT_ERROR_THRESHOLD=5

ADMIN_BOOTSTRAP_ENABLED=0
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
