APP_ENV=local
APP_DEBUG=1
SECRET_KEY=change-this-to-a-long-random-secret
DATABASE_URL=sqlite:///./jewellery.db
RUN_MIGRATIONS_ON_STARTUP=1
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=1
MAX_REQUEST_BODY_BYTES=1048576
HTTPS_REDIRECT=0
TRUSTED_HOSTS=*
PROXY_HEADERS=1
FORWARDED_ALLOW_IPS=*
HOST=0.0.0.0
PORT=7860
WEB_CONCURRENCY=1
UVICORN_LOG_LEVEL=info
RUN_MIGRATIONS_BEFORE_START=0

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=15
EMAIL_VERIFICATION_EXPIRE_MINUTES=30
PASSWORD_MIN_LENGTH=8
LOGIN_FAILURE_LIMIT=5
LOGIN_LOCKOUT_MINUTES=15
RESEND_VERIFICATION_COOLDOWN_SECONDS=60

FRONTEND_VERIFY_URL=http://localhost:3000/verify-email
FRONTEND_RESET_URL=http://localhost:3000/reset-password

EMAIL_PROVIDER=smtp
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=Jewellery Chat
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT_SECONDS=10
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
BREVO_API_KEY=
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

OMS_ENABLED=0
OMS_BASE_URL=
OMS_API_KEY=
OMS_TIMEOUT_SECONDS=10

LLM_ENABLED=0
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=350

MONITORING_WEBHOOK_URL=
MONITORING_WEBHOOK_TIMEOUT_SECONDS=5
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
SENTRY_SEND_DEFAULT_PII=0
ALERT_ERROR_THRESHOLD=5

ADMIN_BOOTSTRAP_ENABLED=0
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
